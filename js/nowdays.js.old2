const infoBtns = [...document.querySelectorAll("#nowdaysInfo button")];
infoBtns.forEach((el) => {
  el.addEventListener("click", () => {
    let dataShow = el.dataset.show;
    document.querySelector(`.${dataShow}`).classList.remove("hide");
  });
});

