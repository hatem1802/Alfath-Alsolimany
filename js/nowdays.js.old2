function displayNowdaysInfoBlock(title, days, classes) {
  let contrainer = createElement("div");
  contrainer.className =
    "block d-flex flex-column align-items-center justify-content-center";
  let h4 = createElement("h4");
  h4.innerHTML = title;
  let grid = createElement("div");
  grid.className = `gap-2 block-content block-grid ${classes?.block}`;
  for (const day of days) {
    let span = createElement("span");
    span.innerHTML = day;
    span.className = `btn btn-success ${classes?.item}`;
    grid.append(span);
  }

  contrainer.append(h4);
  contrainer.append(grid);
  return contrainer;
}
function displayFirstDay(dayNumber) {
  if (!document.getElementById(`nowdaysInfo`)) return;
  let firstDayInYear = STARTING_YEAR[dayNumber];
  let div = document.querySelector(".year-first-day");
  div.innerHTML = `
  <h3 class="year-first-day-title">
     دخول هذه السنة بيوم ${WEEKDAY_NAME[dayNumber]}
  </h3>
  ${firstDayInYear}`;
}

function displayTableYear(year) {
  if (!document.getElementById(`nowdaysInfo`)) return;

  let date = new Date();
  let hijriDate = date.toHijri();
  let hijriYear = hijriDate._year;
  let theYear = year ? year : hijriYear;
  let yearNum = theYear % 210 === 0 ? 210 : theYear % 210;

  for (let i = 1; i <= 12; i++) {
    let hijriMonth = i;
    let monthCount = Calender.countDayOfMonth(hijriMonth, theYear);

    if (Calender.leapYears?.includes(yearNum) && i === 12) {
      monthCount = 30;
    }

    for (let j = 1; j <= monthCount; j++) {
      let row = document.getElementById(`nowdaysList`);
      let monthStatus = EACH_MONTHS_STATUS[j];
      const hijri = new HijriDate(hijriYear, hijriMonth, j);
      // let currentDate = new Date();

      const gerogen = hijri.toGregorian();

      let gerogenDate = new Date(gerogen);
      let currentDate = resetDate(new Date());
      let active =
        gerogenDate.getDate() === currentDate.getDate() &&
        gerogenDate.getMonth() === currentDate.getMonth() &&
        gerogenDate.getFullYear() === currentDate.getFullYear();
      let dayType = "";
      let weekStatus = EACH_WEEK_STATUS[gerogen.getDay()];

      if (hijri._month === 1 && hijri._date === 1) {
        displayFirstDay(gerogenDate.getDay());
      }

      let afterSafer = "";
      let lastWeekStart = monthCount === 30 ? 24 : 23;
      let isBadDay1 = BAD_DAYS_IN_THE_YEAR_1?.[`${hijriMonth}-${j}`];
      let isBadDay2 = BAD_DAYS_IN_THE_YEAR_2?.[`${hijriMonth}-${j}`];
      let badDayInMonth = BAD_DAYS_IN_THE_MONTH[j];
      let isLastWed = j >= lastWeekStart && gerogenDate.getDay() === 3;

      let currentMonth = Calender.months[hijriMonth]
        ?.replace(/شهر/gi, "")
        ?.trim();
      let isBad = false;
      if (SELECTED_DAYS?.[j]) {
        dayType = {
          msg: `${SELECTED_DAYS?.[j]} من شهر ${currentMonth} (سعد)`,
          classes: "active-good",
        };
      }
      if (MIXED_DAYS_NAME?.[j]) {
        dayType = {
          msg: `${MIXED_DAYS_NAME?.[j]} من شهر ${currentMonth} (ممتزج)`,
          classes: "active-normal",
        };
      }
      if (UNLUCKY_DAYS?.[j]) {
        isBad = `${UNLUCKY_DAYS?.[j]} من شهر ${currentMonth} (نحس)`;
        dayType = {
          msg: `${UNLUCKY_DAYS?.[j]} من شهر ${currentMonth} (نحس)`,
          classes: "active-bad should-bad",
        };
      }

      let classes = `${active ? "active-col" : ""} ${
        isBadDay1 || isLastWed ? "active-bad" : ""
      } ${
        ((hijriMonth === 2 && j === 6) || SELECTED_DAYS?.[j]) && !isBadDay1
          ? "active-good"
          : ""
      }`;

      if (hijriMonth === 2 && j === 6) {
        afterSafer = AFTER_SAFAR?.[new Date(gerogen).getDay()];
      }
      let content = ``;
      if (isBadDay1) {
        dayType.classes = "active-bad active-day-year-bad";
        content = `
        <ul class="d-flex flex-column align-items-start mt-2 gap-1 px-2 mb-4">
        ${isBadDay1 ? `<li>- ${isBadDay1}</li>` : ""}
        </ul>`;
      } else if (isLastWed) {
        dayType.classes = "active-bad active-day-year-bad";
        content = `
        <ul class="d-flex flex-column align-items-start mt-2 gap-1 px-2 mb-4">
        <li>- اخر أربعاء  (نحس)</li>
        </ul>`;
      } else if (isBad) {
        dayType.classes = "active-bad active-day-year-bad";
        content = `
        <ul class="d-flex flex-column align-items-start mt-2 gap-1 px-2 mb-4">
        <li>- ${isBad}</li>
        </ul>`;
      } else {
        content = `
        <ul class="d-flex flex-column align-items-start mt-2 gap-1 px-2 mb-4">
  
        ${priorityStatus && afterSafer ? `<li>- ${afterSafer}</li>` : ""}
        ${`<li>- ${dayType.msg}</li>`}
          ${
            priorityMonth
              ? `<li>- ${SELECTED_DAYS_COLLECTION?.[j]} هو: <strong>${monthStatus}</strong></li>`
              : ""
          }
          ${
            priorityWeek
              ? `<li>- 
          ${
            WEEKDAY_NAME?.[new Date(gerogen).getDay()]
          } من كل اسبوع هو يوم: <strong>${weekStatus}</strong></li>`
              : ""
          }
          ${
            badDayInMonth
              ? `<li>- ${SELECTED_DAYS_COLLECTION?.[j]} : ${badDayInMonth}</li>`
              : ""
          }
          ${
            priorityStatus && isBadDay2
              ? `<li>- ${isBadDay2} في ${SELECTED_DAYS_COLLECTION?.[j]} من شهر ${currentMonth} كل سنة </li>`
              : ""
          }
          ${
            priorityStatus && isLastWed
              ? `<li>- اخر أربعاء  ${BADDEST_DAY}</li>`
              : ""
          }
          </ul>
          `;
      }

      let hashId = `${i}-${j}`;

      console.log(
        content,
        "----",
        `${SELECTED_DAYS_COLLECTION?.[j]} من شهر ${currentMonth}`
      );

      row.append(
        displayDayStatus(
          {
            content,
            title: `${SELECTED_DAYS_COLLECTION?.[j]} من شهر ${currentMonth}`,
            date: gerogenDate,
          },
          classes + ` ${dayType?.classes}`,
          active ? "nowdaysToday" : "",
          hashId,
          row
        )
      );
    }
  }
}

function createElement(el) {
  return document.createElement(el);
}

function closestGoodDays(el) {
  let date = new Date(Calender.theCurrentDate.gregorianDate);
  let hijriDate = date.toHijri();

  for (let i = 0; i < 5; i++) {
    if (i > 0) hijriDate.addDay();

    let monthCount = Calender.countDayOfMonth(
      hijriDate._month,
      hijriDate._year
    );
    const gerogenDate = hijriDate.toGregorian();
    let dateNumber = hijriDate._date;
    let lastWeekStart = monthCount === 30 ? 24 : 23;

    let isBadDay1 =
      BAD_DAYS_IN_THE_YEAR_1?.[`${hijriDate._month}-${dateNumber}`];
    let isBadDay2 =
      BAD_DAYS_IN_THE_YEAR_2?.[`${hijriDate._month}-${dateNumber}`];
    let isLastWed = dateNumber >= lastWeekStart && gerogenDate.getDay() === 3;
    let badDayInMonth = BAD_DAYS_IN_THE_MONTH[i];

    let isBad = isBadDay1 || isBadDay2 || isLastWed || badDayInMonth;
    let currentGreDate = hijriDate.toGregorian();
    let currentMonth = Calender.months[hijriDate._month]
      ?.replace(/شهر/gi, "")
      ?.trim();
    let content = ``;

    if (UNLUCKY_DAYS?.[dateNumber] || isBad || isLastWed) {
      // content = `<span class="active-text-bad">${SELECTED_DAYS_COLLECTION?.[dateNumber]} من شهر ${currentMonth} (نحس)</span>`;
      // if (isLastWed) content = `<span class="active-text-bad">${SELECTED_DAYS_COLLECTION?.[dateNumber]} اخر اربعاء من كل شهر (نحس)</span>`;
      // else if (isBadDay1 || isBadDay2 || badDayInMonth)
      // else
        content = `<span class="active-text-bad">${SELECTED_DAYS_COLLECTION?.[dateNumber]} من شهر ${currentMonth} (نحس)</span>`;
    } else if (SELECTED_DAYS?.[dateNumber]) {
      content = `<span class="active-text-good">${SELECTED_DAYS?.[dateNumber]} من شهر ${currentMonth} (سعد)</span>`;
    } else if (MIXED_DAYS_NAME?.[dateNumber]) {
      content = `<span class="active-text-normal">${MIXED_DAYS_NAME?.[dateNumber]} من شهر ${currentMonth} (ممتزج)</span>`;
    }

    el.innerHTML += `
    <div class="table-style-grid">
    <h4>${content}</h4>
    <span class="timer-style timer">${calculateDate(
      new Date(currentGreDate).toISOString()
    )}</span>
  </div>`;
  }
}

function displayDayStatus(item, classes, id, hashId, row) {
  let li = document.createElement("li");
  let gregorian = new Date(item.date).toLocaleDateString("ar-EG", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
  if (id) {
    let span = document.createElement("li");
    span.id = id;
    span.className = "my-4";
    row.append(span);
  }
  li.id = hashId;
  let hijri = new Date(item.date).toHijri();
  li.className = `events-item __counter_2 ${classes}`;
  li.innerHTML += `
    <span type="" id="${id}" ></span>
    <h4 class="font-bold" >${item.title}</h4>
    ${item?.content}
    <p class="d-flex align-items justify-content-between">
    <span>${new Date(item.date).toLocaleDateString("ar-SA", {
      weekday: "long",
    })} ${hijri._date} ${Calender.months[hijri._month]} ${hijri._year}</span>
      <span  class="text-danger">${gregorian}</span>
      </p>
      ${calculateDate(item.date)}
  `;
  return li;
}
// <p class="d-flex flex-column gap-2 align-items-start px-2 my-2"></p>

function goToDay() {
  let month = document.querySelector(".go-to-day__month").value;
  let day = document.querySelector(".go-to-day__day").value;
  const regex = /^(1[0-2]|[2-9])-([2-9]|[12][0-9]|30)$/;

  const element = document.getElementById(`${month}-${day}`);
  element.scrollIntoView();
}
